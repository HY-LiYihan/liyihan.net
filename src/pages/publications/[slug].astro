---
import { getCollection, render } from "astro:content";
import ContentLayout from "../../layouts/ContentLayout.astro";

export async function getStaticPaths() {
  const publications = await getCollection("publications");
  return publications.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<ContentLayout
  title={entry.data.title}
  description={entry.data.description}
>
  <p class="meta">
    {entry.data.authors.join(", ")} · {entry.data.venue}, {entry.data.year}
  </p>
  <Content />
  <div class="button-row">
    {entry.data.paper && <a class="button primary" href={entry.data.paper}>Paper</a>}
    {entry.data.code && <a class="button" href={entry.data.code}>Code</a>}
    {entry.data.project && <a class="button" href={entry.data.project}>Project</a>}
  </div>
</ContentLayout>
