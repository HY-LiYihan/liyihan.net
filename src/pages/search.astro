---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Search" description="Search liyihan.net.">
  <section class="section prose">
    <p class="eyebrow">Search</p>
    <h1>Search</h1>
    <p class="lede">Search is indexed by Pagefind after the static build.</p>
    <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
    <script src="/pagefind/pagefind-ui.js" is:inline></script>
    <div id="search" class="search-box"></div>
    <script is:inline>
      window.addEventListener("DOMContentLoaded", () => {
        if (window.PagefindUI) {
          new window.PagefindUI({ element: "#search", showSubResults: true });
        }
      });
    </script>
  </section>
</BaseLayout>
