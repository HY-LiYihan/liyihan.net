---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ContentCard from "../../components/ContentCard.astro";

const blog = await getCollection("blog");
const projects = await getCollection("projects");
const publications = await getCollection("publications");

function collectEntries() {
  return [
    ...blog
      .filter((entry) => !entry.data.draft)
      .map((entry) => ({ ...entry, section: "blog" })),
    ...projects
      .filter((entry) => !entry.data.draft)
      .map((entry) => ({ ...entry, section: "projects" })),
    ...publications.map((entry) => ({ ...entry, section: "publications" })),
  ];
}

export async function getStaticPaths() {
  const blog = await getCollection("blog");
  const projects = await getCollection("projects");
  const publications = await getCollection("publications");
  const allEntries = [
    ...blog
      .filter((entry) => !entry.data.draft)
      .map((entry) => ({ ...entry, section: "blog" })),
    ...projects
      .filter((entry) => !entry.data.draft)
      .map((entry) => ({ ...entry, section: "projects" })),
    ...publications.map((entry) => ({ ...entry, section: "publications" })),
  ];
  const tags = new Set<string>();
  for (const entry of allEntries) {
    entry.data.tags.forEach((tag) => tags.add(tag));
  }
  return Array.from(tags).map((tag) => ({ params: { tag } }));
}

const tag = Astro.params.tag ?? "";
const allEntries = collectEntries();
const entries = allEntries.filter((entry) => entry.data.tags.includes(tag));
---

<BaseLayout title={`Tag: ${tag}`} description={`Content tagged ${tag}.`}>
  <section class="section">
    <p class="eyebrow">Tag</p>
    <h1>{tag}</h1>
    <div class="list">
      {
        entries.map((entry) => (
          <ContentCard
            title={entry.data.title}
            description={entry.data.description}
            href={`/${entry.section}/${entry.id}/`}
            tags={entry.data.tags}
          />
        ))
      }
    </div>
  </section>
</BaseLayout>
