---
import { getCollection, render } from "astro:content";
import ContentLayout from "../../layouts/ContentLayout.astro";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects
    .filter((entry) => !entry.data.draft)
    .map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<ContentLayout
  title={entry.data.title}
  description={entry.data.description}
  date={entry.data.date}
>
  <Content />
  <div class="button-row">
    {entry.data.repo && <a class="button" href={entry.data.repo}>Repository</a>}
    {entry.data.demo && <a class="button primary" href={entry.data.demo}>Demo</a>}
    {entry.data.paper && <a class="button" href={entry.data.paper}>Paper</a>}
  </div>
</ContentLayout>
