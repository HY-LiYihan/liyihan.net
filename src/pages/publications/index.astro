---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ContentCard from "../../components/ContentCard.astro";

const publications = (await getCollection("publications")).sort(
  (a, b) => b.data.year - a.data.year,
);
---

<BaseLayout title="Publications" description="Selected publications and papers.">
  <section class="section">
    <p class="eyebrow">Research output</p>
    <h1>Publications</h1>
    <p class="lede">
      Publication entries can later be generated from BibTeX or maintained as
      MDX pages with paper links, code, and project context.
    </p>
    <div class="list">
      {
        publications.map((entry) => (
          <ContentCard
            title={entry.data.title}
            description={entry.data.description}
            href={`/publications/${entry.id}/`}
            meta={`${entry.data.venue}, ${entry.data.year} · ${entry.data.authors.join(", ")}`}
            tags={entry.data.tags}
          />
        ))
      }
    </div>
  </section>
</BaseLayout>
