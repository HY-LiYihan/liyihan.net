---
interface Props {
  title: string;
  description: string;
  href: string;
  meta?: string;
  tags?: string[];
}

const { title, description, href, meta, tags = [] } = Astro.props;
---

<article class="card">
  {meta && <p class="meta">{meta}</p>}
  <h3><a href={href}>{title}</a></h3>
  <p>{description}</p>
  {
    tags.length > 0 && (
      <div class="tag-row">
        {tags.map((tag) => (
          <a class="tag" href={`/tags/${encodeURIComponent(tag)}/`}>
            {tag}
          </a>
        ))}
      </div>
    )
  }
</article>
